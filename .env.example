# --- Phase 1: Core ---------------------------------------------------------
# Path to the SQLite database file (relative to project root or absolute).
DB_PATH=./data/b-leads.db

# --- Phase 3: LLM provider --------------------------------------------------
# Which LLM provider to use: mock | ollama | mistral. Default: mock (dev).
LLM_PROVIDER=mock

# Ollama (local, e.g. Qwen2.5 7B) — OpenAI-compatible endpoint.
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=qwen2.5:7b

# Mistral (production) — OpenAI-compatible endpoint.
# MISTRAL_API_KEY=
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# MISTRAL_MODEL=mistral-small-latest

# --- Phase 2: IMAP inbox sync ----------------------------------------------
# IMAP_HOST=
# IMAP_PORT=993
# IMAP_USER=
# IMAP_PASSWORD=
# IMAP_TLS=true

# --- Auth: Magic-Link + Allowlist ------------------------------------------
# Comma-separated list of email addresses allowed to request a login link.
# Non-allowlisted addresses are silently rejected (no user enumeration).
AUTH_ALLOWLIST=

# Secret used to HMAC-sign magic-link tokens. Rotate to invalidate all
# outstanding tokens. Long random string (>= 32 bytes).
AUTH_TOKEN_SECRET=

# Time-to-live for a magic-link token, in minutes. Default: 15.
# AUTH_TOKEN_TTL_MINUTES=15

# Public base URL used to build magic-link URLs (no trailing slash).
APP_BASE_URL=http://localhost:4321

# Mail provider: mock | smtp. Default: mock (dev — logs the link to stdout).
# `smtp` works with any transactional provider that speaks SMTP (Brevo,
# Postmark, Mailgun, SendGrid, or your own relay). Configure via SMTP_* below.
MAIL_PROVIDER=mock

# SMTP transport (required when MAIL_PROVIDER=smtp).
# Example for Brevo: host=smtp-relay.brevo.com, port=587, secure=false,
# user=<your Brevo account email>, pass=<SMTP key from the Brevo dashboard,
# NOT the API key>. Port 465 → SMTP_SECURE=true; port 587 → false.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# AUTH_FROM_EMAIL=noreply@example.com
# AUTH_FROM_NAME=b-leads
