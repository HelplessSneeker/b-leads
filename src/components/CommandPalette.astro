---
import { actions } from 'astro:actions';
import { STATUS_CLASSES, STATUS_LABELS } from '~/components/leadStatus';
import { LEAD_STATUSES } from '~/db/schema';

// Keyboard layer for the console (PRODUCT.md: "keyboard-forward"). Rendered once
// in Layout. Three pieces:
//   1. A command palette (⌘K / Ctrl+K, or `:`) — fuzzy-filter + run any command.
//   2. Global shortcuts: g t / g l navigate, n new, i import, / focus search,
//      ? help, j/k/Enter row navigation on any [data-nav-list] table.
//   3. A help sheet (?) listing every binding.
// Everything is progressive: the commands are real <a>/<button> elements, so the
// palette works without the enhancer too; the script only adds filter + keys.

type Command =
  | { id: string; label: string; hint: string; keys?: string; href: string }
  | { id: string; label: string; hint: string; keys?: string; action: 'search' | 'help' };

const commands: Command[] = [
  { id: 'today', label: 'Heute', hint: 'Fällige & stille Leads', keys: 'g t', href: '/today' },
  { id: 'leads', label: 'Leads', hint: 'Alle Leads', keys: 'g l', href: '/leads' },
  { id: 'new', label: 'Neuer Lead', hint: 'Lead anlegen', keys: 'n', href: '/leads/new' },
  {
    id: 'import',
    label: 'CSV-Import',
    hint: 'Leads importieren',
    keys: 'i',
    href: '/leads/import',
  },
  {
    id: 'search',
    label: 'Suche fokussieren',
    hint: 'In der Liste suchen',
    keys: '/',
    action: 'search',
  },
  ...LEAD_STATUSES.map((s) => ({
    id: `status-${s}`,
    label: `Filter: ${STATUS_LABELS[s]}`,
    hint: 'Leads nach Status',
    href: `/leads?status=${s}`,
  })),
  { id: 'help', label: 'Tastaturkürzel', hint: 'Alle Kürzel anzeigen', keys: '?', action: 'help' },
];

const shortcuts: { keys: string[]; label: string }[] = [
  { keys: ['⌘', 'K'], label: 'Befehlspalette öffnen' },
  { keys: ['/'], label: 'Suche fokussieren' },
  { keys: ['g', 't'], label: 'Zu Heute' },
  { keys: ['g', 'l'], label: 'Zu Leads' },
  { keys: ['n'], label: 'Neuer Lead' },
  { keys: ['i'], label: 'CSV-Import' },
  { keys: ['j'], label: 'Zeile abwärts' },
  { keys: ['k'], label: 'Zeile aufwärts' },
  { keys: ['↵'], label: 'Ausgewählte Zeile öffnen' },
  { keys: ['s'], label: 'Status der Zeile ändern' },
  { keys: ['?'], label: 'Diese Hilfe' },
  { keys: ['Esc'], label: 'Schließen' },
];
---

<dialog id="cmdk" class="cmdk" aria-label="Befehlspalette" transition:persist="cmdk">
  <div class="cmdk-panel">
    <input
      id="cmdk-input"
      type="text"
      class="cmdk-input"
      placeholder="Befehl oder Sprung…"
      autocomplete="off"
      spellcheck="false"
      aria-controls="cmdk-list"
      aria-expanded="true"
    />
    <ul id="cmdk-list" class="cmdk-list" role="listbox" aria-label="Befehle">
      {
        commands.map((cmd) => (
          <li role="option" class="cmdk-item" data-cmd-id={cmd.id} data-label={cmd.label}>
            <a
              class="cmdk-link"
              href={'href' in cmd ? cmd.href : '#'}
              data-action={'action' in cmd ? cmd.action : undefined}
            >
              <span class="cmdk-item-label">{cmd.label}</span>
              <span class="cmdk-item-hint">{cmd.hint}</span>
              {cmd.keys && <kbd class="cmdk-item-keys">{cmd.keys}</kbd>}
            </a>
          </li>
        ))
      }
      <li id="cmdk-empty" class="cmdk-empty" hidden>Kein Treffer.</li>
    </ul>
    <footer class="cmdk-footer">
      <span><kbd>↑</kbd><kbd>↓</kbd> navigieren</span>
      <span><kbd>↵</kbd> ausführen</span>
      <span><kbd>esc</kbd> schließen</span>
    </footer>
  </div>
</dialog>

<dialog id="kbd-help" class="cmdk" aria-label="Tastaturkürzel" transition:persist="kbd-help">
  <div class="cmdk-panel cmdk-panel--help">
    <h2 class="kbd-help-title">Tastaturkürzel</h2>
    <ul class="kbd-help-list">
      {
        shortcuts.map((s) => (
          <li class="kbd-help-row">
            <span class="kbd-help-keys">
              {s.keys.map((k) => (
                <kbd>{k}</kbd>
              ))}
            </span>
            <span class="kbd-help-label">{s.label}</span>
          </li>
        ))
      }
    </ul>
    <footer class="cmdk-footer">
      <span><kbd>esc</kbd> schließen</span>
    </footer>
  </div>
</dialog>

<dialog id="status-dialog" class="cmdk" aria-label="Status ändern" transition:persist="status-dialog">
  <div class="cmdk-panel cmdk-panel--status">
    <p class="status-title">Status ändern<span class="status-lead" data-status-name></span></p>
    <form method="POST" action={actions.updateLeadStatus} data-status-form>
      <input type="hidden" name="id" data-status-id />
      <input type="hidden" name="returnTo" data-status-returnto />
      <ul class="status-options" role="list">
        {
          LEAD_STATUSES.map((s) => (
            <li>
              <button type="submit" name="status" value={s} class="status-option" data-status-value={s}>
                <span class:list={['tag', STATUS_CLASSES[s]]}>{STATUS_LABELS[s]}</span>
                <span class="status-current" data-current-label hidden>
                  aktuell
                </span>
              </button>
            </li>
          ))
        }
      </ul>
    </form>
    <footer class="cmdk-footer">
      <span><kbd>↑</kbd><kbd>↓</kbd> wählen</span>
      <span><kbd>↵</kbd> ändern</span>
      <span><kbd>esc</kbd> abbrechen</span>
    </footer>
  </div>
</dialog>

<style>
  /* Native <dialog> escapes every stacking/overflow context (skill guidance:
     don't trap an overlay inside an overflow:auto container). */
  .cmdk {
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
  }
  .cmdk::backdrop {
    background: var(--scrim);
    backdrop-filter: blur(2px);
  }
  .cmdk[open] {
    /* Anchor the panel toward the top — command-bar convention, and it keeps the
       list stable as it shrinks while filtering. */
    position: fixed;
    inset: 0;
    /* The native <dialog> UA stylesheet sets width/height: fit-content, so
       inset:0 alone leaves the box content-sized and pinned to the left edge.
       Reset to auto so the inset offsets stretch it across the viewport — only
       then does place-content actually center the panel. */
    width: auto;
    height: auto;
    display: grid;
    place-content: start center;
    padding-top: 12vh;
  }

  .cmdk-panel {
    width: min(34rem, calc(100vw - 2rem));
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-overlay);
    box-shadow: var(--overlay-shadow);
    overflow: hidden;
  }

  .cmdk-input {
    width: 100%;
    background: transparent;
    color: var(--ink);
    border: none;
    border-bottom: 1px solid var(--border);
    padding: 12px 14px;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.4;
  }
  .cmdk-input::placeholder {
    color: var(--muted);
  }
  .cmdk-input:focus {
    outline: none;
  }

  .cmdk-list {
    list-style: none;
    margin: 0;
    padding: 4px;
    max-height: min(24rem, 60vh);
    overflow-y: auto;
    /* Scrollbar chrome is themed globally (see global.css @layer base); contain
       overscroll so wheel momentum doesn't leak to the page behind the dialog. */
    overscroll-behavior: contain;
  }

  .cmdk-link {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 7px 10px;
    border-radius: 3px;
    color: var(--ink);
    text-decoration: none;
  }
  /* Roving highlight follows keyboard selection and hover; the indigo accent is an
     interaction signal here (selection), consistent with the Two Vocabularies rule. */
  .cmdk-item[data-active] .cmdk-link {
    background: var(--surface-sunken);
    box-shadow: inset 2px 0 0 var(--accent);
  }
  .cmdk-item[hidden] {
    display: none;
  }

  .cmdk-item-label {
    font-size: 0.875rem;
    font-weight: 500;
  }
  .cmdk-item-hint {
    flex: 1;
    color: var(--muted);
    font-size: 0.8125rem;
  }
  .cmdk-item-keys,
  .cmdk-footer kbd,
  .kbd-help-keys kbd {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--muted);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1px 5px;
    white-space: nowrap;
  }

  .cmdk-empty {
    padding: 14px 12px;
    color: var(--muted);
    font-size: 0.875rem;
    text-align: center;
  }

  .cmdk-footer {
    display: flex;
    gap: 14px;
    padding: 8px 12px;
    border-top: 1px solid var(--border);
    background: var(--surface-sunken);
    color: var(--muted);
    font-size: 0.75rem;
  }
  .cmdk-footer span {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  /* Help sheet */
  .cmdk-panel--help {
    padding: 16px 18px 0;
  }
  .kbd-help-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--ink);
  }
  .kbd-help-list {
    list-style: none;
    margin: 12px 0;
    padding: 0;
    display: grid;
    gap: 6px;
  }
  .kbd-help-row {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.875rem;
  }
  .kbd-help-keys {
    display: inline-flex;
    gap: 4px;
    min-width: 4.5rem;
  }
  .kbd-help-label {
    color: var(--ink);
  }
  .cmdk-panel--help .cmdk-footer {
    margin: 0 -18px;
  }

  /* Status picker — same overlay vocabulary as the palette, narrower. Opened for
     the keyboard-selected row (`s`) or by clicking a row's status tag. Confirmable:
     status only changes when an option is explicitly chosen, never on a passive
     scroll/arrow the way the old inline auto-submitting <select> could. */
  .cmdk-panel--status {
    width: min(22rem, calc(100vw - 2rem));
  }
  .status-title {
    padding: 12px 14px;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--ink);
  }
  .status-lead {
    color: var(--muted);
    font-weight: 400;
  }
  .status-options {
    list-style: none;
    margin: 0;
    padding: 4px;
    display: grid;
    gap: 2px;
    max-height: min(20rem, 60vh);
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .status-option {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    text-align: left;
    padding: 7px 10px;
    border: none;
    border-radius: 3px;
    background: transparent;
    cursor: pointer;
    font: inherit;
  }
  /* Roving keyboard focus / hover = interaction highlight (surface tone), keeping
     the indigo accent for the focus ring only — the Two Vocabularies rule. */
  .status-option:hover,
  .status-option:focus-visible {
    background: var(--surface-sunken);
  }
  /* Touch: full 44px tap target for the picker options (room to spare in the modal). */
  @media (pointer: coarse) {
    .status-option {
      min-height: 44px;
    }
  }
  /* "aktuell" marks the current status as state, never with the interaction accent. */
  .status-current {
    margin-left: auto;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Entrance: brief fade + lift. ~75% exit handled by the [open] gate. */
  @keyframes cmdk-in {
    from {
      opacity: 0;
      transform: translateY(-6px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  .cmdk[open] .cmdk-panel {
    animation: cmdk-in 160ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes cmdk-backdrop-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  .cmdk[open]::backdrop {
    animation: cmdk-backdrop-in 160ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .cmdk[open] .cmdk-panel,
    .cmdk[open]::backdrop {
      animation: none;
    }
  }
</style>

<script>
  type Dialog = HTMLDialogElement;

  const palette = document.getElementById('cmdk') as Dialog | null;
  const help = document.getElementById('kbd-help') as Dialog | null;
  const input = document.getElementById('cmdk-input') as HTMLInputElement | null;
  const list = document.getElementById('cmdk-list');
  const emptyEl = document.getElementById('cmdk-empty');
  if (!palette || !help || !input || !list || !emptyEl) {
    // Nothing to wire if the markup is absent; bail quietly.
  } else {
    const items = Array.from(list.querySelectorAll<HTMLLIElement>('.cmdk-item'));
    let activeIndex = 0;

    // ── Status picker (confirmable status change) ────────────────────────────
    // Persisted like the palette so these refs stay valid across view transitions.
    const statusDialog = document.getElementById('status-dialog') as Dialog | null;
    const statusForm = statusDialog?.querySelector<HTMLFormElement>('[data-status-form]') ?? null;
    const statusId = statusDialog?.querySelector<HTMLInputElement>('[data-status-id]') ?? null;
    const statusReturnTo =
      statusDialog?.querySelector<HTMLInputElement>('[data-status-returnto]') ?? null;
    const statusName = statusDialog?.querySelector<HTMLElement>('[data-status-name]') ?? null;
    const statusOptions = statusDialog
      ? Array.from(statusDialog.querySelectorAll<HTMLButtonElement>('.status-option'))
      : [];

    // The list URL to return to after the change, minus any stale toast params.
    const listReturnTo = (): string => {
      const url = new URL(window.location.href);
      for (const k of ['changed', 'from', 'to']) url.searchParams.delete(k);
      const qs = url.searchParams.toString();
      return qs ? `${url.pathname}?${qs}` : url.pathname;
    };

    const openStatusPicker = (id: string, status: string, name: string) => {
      if (!statusDialog || !statusId || !statusReturnTo) return;
      if (palette.open || help.open || statusDialog.open) return;
      statusId.value = id;
      statusReturnTo.value = listReturnTo();
      if (statusName) statusName.textContent = name ? ` · ${name}` : '';
      // Mark the current status (state, via the muted "aktuell" label) and focus it.
      let focusTarget: HTMLButtonElement | undefined = statusOptions[0];
      for (const opt of statusOptions) {
        const isCurrent = opt.dataset.statusValue === status;
        const label = opt.querySelector<HTMLElement>('[data-current-label]');
        if (label) label.hidden = !isCurrent;
        if (isCurrent) focusTarget = opt;
      }
      statusDialog.showModal();
      focusTarget?.focus();
    };

    // Arrow keys rove focus across the options; Enter submits the focused button
    // (native), Esc closes (native). Close on submit so the persisted dialog isn't
    // left open across the post-change navigation.
    statusDialog?.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
      e.preventDefault();
      const here = statusOptions.indexOf(document.activeElement as HTMLButtonElement);
      const dir = e.key === 'ArrowDown' ? 1 : -1;
      const next = ((here === -1 ? 0 : here) + dir + statusOptions.length) % statusOptions.length;
      statusOptions[next]?.focus();
    });
    statusForm?.addEventListener('submit', () => statusDialog?.close());
    // Light dismiss: clicking the backdrop closes. When the dialog fills the
    // viewport, the empty area around the panel is the dialog element itself,
    // so target === dialog means a backdrop click. Guard with the pointerdown
    // target so a drag that starts inside the panel and ends outside (text
    // select) doesn't close it.
    let statusPointerDownTarget: EventTarget | null = null;
    statusDialog?.addEventListener('pointerdown', (e) => {
      statusPointerDownTarget = e.target;
    });
    statusDialog?.addEventListener('click', (e) => {
      if (e.target === statusDialog && statusPointerDownTarget === statusDialog) {
        statusDialog.close();
      }
    });

    const isTypingContext = (el: EventTarget | null): boolean => {
      const node = el as HTMLElement | null;
      if (!node) return false;
      const tag = node.tagName;
      return (
        tag === 'INPUT' ||
        tag === 'TEXTAREA' ||
        tag === 'SELECT' ||
        node.isContentEditable === true
      );
    };

    const visibleItems = () => items.filter((i) => !i.hidden);

    const setActive = (idx: number) => {
      const vis = visibleItems();
      if (vis.length === 0) return;
      const clamped = (idx + vis.length) % vis.length;
      for (const it of items) delete it.dataset.active;
      const el = vis[clamped];
      el.dataset.active = '';
      activeIndex = items.indexOf(el);
      el.scrollIntoView({ block: 'nearest' });
    };

    const filter = (query: string) => {
      const q = query.trim().toLowerCase();
      let anyVisible = false;
      for (const it of items) {
        const label = (it.dataset.label ?? '').toLowerCase();
        // Subsequence match so "nl" finds "Neuer Lead".
        const match = q === '' || subsequence(q, label) || label.includes(q);
        it.hidden = !match;
        if (match) anyVisible = true;
      }
      emptyEl.hidden = anyVisible;
      const first = visibleItems()[0];
      if (first) setActive(items.indexOf(first));
    };

    const subsequence = (needle: string, hay: string): boolean => {
      let i = 0;
      for (const ch of hay) if (ch === needle[i]) i++;
      return i === needle.length;
    };

    const openPalette = () => {
      if (palette.open || help.open || statusDialog?.open) return;
      input.value = '';
      filter('');
      palette.showModal();
      input.focus();
    };

    const runActive = () => {
      const el = items[activeIndex];
      if (!el || el.hidden) return;
      const link = el.querySelector<HTMLAnchorElement>('.cmdk-link');
      if (!link) return;
      const action = link.dataset.action;
      palette.close();
      if (action === 'search') focusSearch();
      else if (action === 'help') help.showModal();
      else window.location.assign(link.getAttribute('href') ?? '/');
    };

    const focusSearch = () => {
      const search = document.querySelector<HTMLInputElement>('[data-search]');
      if (search) {
        search.focus();
        search.select();
      } else {
        window.location.assign('/leads');
      }
    };

    // ── Palette-local keys ──────────────────────────────────────────────────
    input.addEventListener('input', () => filter(input.value));
    const moveActive = (dir: 1 | -1) => {
      const vis = visibleItems();
      if (vis.length === 0) return;
      const pos = vis.indexOf(items[activeIndex]);
      const nextPos = ((pos === -1 ? 0 : pos) + dir + vis.length) % vis.length;
      setActive(items.indexOf(vis[nextPos]));
    };

    palette.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown' || (e.key === 'n' && e.ctrlKey)) {
        e.preventDefault();
        moveActive(1);
      } else if (e.key === 'ArrowUp' || (e.key === 'p' && e.ctrlKey)) {
        e.preventDefault();
        moveActive(-1);
      } else if (e.key === 'Enter') {
        e.preventDefault();
        runActive();
      }
    });

    // Click selects + runs (close first so navigation isn't blocked by the modal).
    for (const it of items) {
      const link = it.querySelector<HTMLAnchorElement>('.cmdk-link');
      link?.addEventListener('click', (e) => {
        const action = link.dataset.action;
        if (action) {
          e.preventDefault();
          palette.close();
          if (action === 'search') focusSearch();
          else if (action === 'help') help.showModal();
        }
        // plain href links navigate natively after the dialog closes on click.
      });
      it.addEventListener('mousemove', () => {
        if (!it.hidden) setActive(items.indexOf(it));
      });
    }

    // Mouse affordance: the [data-cmdk-open] trigger (header button). Delegated on
    // document so it survives view transitions swapping the header out from under us.
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (target?.closest('[data-cmdk-open]')) openPalette();
      // A row's status tag is a button that opens the picker for that row.
      if (target?.closest('[data-status-trigger]')) {
        const row = target.closest<HTMLElement>('[data-nav-row]');
        if (row?.dataset.leadId) {
          openStatusPicker(row.dataset.leadId, row.dataset.status ?? '', row.dataset.name ?? '');
        }
      }
    });

    // ── Global shortcuts ────────────────────────────────────────────────────
    let pendingG = false;
    let gTimer: ReturnType<typeof setTimeout> | undefined;

    document.addEventListener('keydown', (e) => {
      // ⌘K / Ctrl+K opens the palette from anywhere (even inside inputs).
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        openPalette();
        return;
      }
      if (e.defaultPrevented || e.metaKey || e.ctrlKey || e.altKey) return;
      // The status picker owns its own keys (native Enter/Esc + arrow roving).
      if (statusDialog?.open) return;
      // Don't hijack typing.
      if (isTypingContext(e.target)) return;

      // `g` prefix for go-to sequences.
      if (pendingG) {
        pendingG = false;
        clearTimeout(gTimer);
        if (e.key === 't') {
          e.preventDefault();
          window.location.assign('/today');
          return;
        }
        if (e.key === 'l') {
          e.preventDefault();
          window.location.assign('/leads');
          return;
        }
      }

      switch (e.key) {
        case 'g':
          pendingG = true;
          gTimer = setTimeout(() => {
            pendingG = false;
          }, 600);
          break;
        case '/':
          e.preventDefault();
          focusSearch();
          break;
        case ':':
          e.preventDefault();
          openPalette();
          break;
        case 'n':
          e.preventDefault();
          window.location.assign('/leads/new');
          break;
        case 'i':
          e.preventDefault();
          window.location.assign('/leads/import');
          break;
        case '?':
          e.preventDefault();
          if (!help.open) help.showModal();
          break;
        case 'j':
          e.preventDefault();
          moveRow(1);
          break;
        case 'k':
          e.preventDefault();
          moveRow(-1);
          break;
        case 's':
          e.preventDefault();
          openStatusForActiveRow();
          break;
        case 'Enter': {
          // If a real control (the status tag, the name link) is focused, let it
          // act natively instead of also opening the keyboard-selected row.
          const el = e.target as HTMLElement | null;
          if (el?.closest('a, button')) break;
          openActiveRow();
          break;
        }
      }
    });

    // ── Row navigation over any [data-nav-list] on the page ──────────────────
    // navRows is page-specific, so it's re-resolved on every astro:page-load (see
    // the bottom of this block). The keydown handler reads it through this binding.
    let navRows: HTMLElement[] = [];
    let rowIndex = -1;

    const setRow = (idx: number) => {
      if (navRows.length === 0) return;
      const clamped = Math.max(0, Math.min(idx, navRows.length - 1));
      for (const r of navRows) delete r.dataset.navActive;
      const row = navRows[clamped];
      row.dataset.navActive = '';
      row.scrollIntoView({ block: 'nearest' });
      rowIndex = clamped;
    };

    function moveRow(dir: 1 | -1) {
      if (navRows.length === 0) return;
      setRow(rowIndex === -1 ? (dir === 1 ? 0 : navRows.length - 1) : rowIndex + dir);
    }

    function openActiveRow() {
      if (rowIndex < 0) return;
      const href = navRows[rowIndex]?.dataset.href;
      if (href) window.location.assign(href);
    }

    // `s` on the keyboard-selected row opens the confirmable status picker.
    function openStatusForActiveRow() {
      if (rowIndex < 0) return;
      const row = navRows[rowIndex];
      if (!row?.dataset.leadId) return;
      openStatusPicker(row.dataset.leadId, row.dataset.status ?? '', row.dataset.name ?? '');
    }

    const resolveRows = () => {
      const rowLists = Array.from(document.querySelectorAll<HTMLElement>('[data-nav-list]'));
      navRows = rowLists.flatMap((l) =>
        Array.from(l.querySelectorAll<HTMLElement>('[data-nav-row]')),
      );
      rowIndex = -1;
      for (const [i, row] of navRows.entries()) {
        row.addEventListener('mouseenter', () => {
          rowIndex = i;
        });
      }
      // After a status change the server re-renders with the changed row flagged
      // (data-flash). Re-select it so keyboard position + scroll survive the PRG
      // round-trip — the operator keeps their place mid-triage instead of resetting
      // to the top of the list on every change.
      const flashed = navRows.findIndex((row) => row.hasAttribute('data-flash'));
      if (flashed >= 0) setRow(flashed);
    };

    // ClientRouter does not re-run this module after a view transition, so the
    // page-specific row list is rebuilt on every astro:page-load (which also fires
    // on the initial load). The palette dialogs persist via transition:persist, so
    // their wiring above stays valid across navigations.
    document.addEventListener('astro:page-load', resolveRows);
  }
</script>
