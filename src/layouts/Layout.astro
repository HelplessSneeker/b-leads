---
import '~/styles/global.css';

interface Props {
  title?: string;
}

const { title = 'b-leads' } = Astro.props;
const { pathname } = Astro.url;

const nav = [
  { href: '/today', label: 'Heute' },
  { href: '/leads', label: 'Leads' },
  { href: '/leads/new', label: 'Neuer Lead' },
  { href: '/leads/import', label: 'CSV-Import' },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-bg text-ink">
    <header class="border-b border-border bg-surface">
      <nav class="mx-auto flex max-w-5xl items-center gap-6 px-4 py-3">
        <a href="/today" class="text-[0.9375rem] font-semibold tracking-tight">b-leads</a>
        <ul class="flex gap-5 text-sm">
          {
            nav.map((item) => {
              const active = pathname === item.href;
              return (
                <li>
                  <a
                    href={item.href}
                    aria-current={active ? 'page' : undefined}
                    class:list={[
                      'inline-block border-b-2 pb-[3px] transition-colors',
                      active
                        ? 'border-accent font-semibold text-ink'
                        : 'border-transparent text-muted hover:text-ink',
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>
    </header>
    <main class="mx-auto max-w-5xl px-4 py-8">
      <slot />
    </main>
  </body>
</html>
