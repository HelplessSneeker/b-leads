---
import { actions } from 'astro:actions';
import { ClientRouter } from 'astro:transitions';
import '~/styles/global.css';
import CommandPalette from '~/components/CommandPalette.astro';

interface Props {
  title?: string;
}

const { title = 'b-leads' } = Astro.props;
const { pathname } = Astro.url;

const nav = [
  { href: '/today', label: 'Heute' },
  { href: '/leads', label: 'Leads' },
  { href: '/leads/new', label: 'Neuer Lead' },
  { href: '/leads/import', label: 'CSV-Import' },
];

const sessionEmail = (await Astro.session?.get('email')) ?? null;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="flex h-screen flex-col bg-bg text-ink">
    <header class="shrink-0 border-b border-border bg-surface">
      <nav class="mx-auto flex max-w-6xl items-center gap-6 px-2 py-3">
        <a href="/today" class="text-[0.9375rem] font-semibold tracking-tight">b-leads</a>
        <ul class="flex gap-5 text-sm">
          {
            nav.map((item) => {
              const active = pathname === item.href;
              return (
                <li>
                  <a
                    href={item.href}
                    aria-current={active ? 'page' : undefined}
                    class:list={[
                      'inline-block border-b-2 pb-[3px] transition-colors',
                      active
                        ? 'border-accent font-semibold text-ink'
                        : 'border-transparent text-muted hover:text-ink',
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })
          }
        </ul>
        <button
          type="button"
          data-cmdk-open
          aria-label="Befehlspalette öffnen"
          class="ml-auto inline-flex items-center gap-2 rounded-sm border border-border bg-bg px-2 py-1 text-muted transition-colors hover:text-ink"
        >
          <span class="text-sm">Befehle</span>
          <kbd class="data text-[0.6875rem] text-muted">⌘K</kbd>
        </button>
        {
          sessionEmail && (
            <form method="POST" action={actions.logout} class="flex items-center gap-2">
              <span class="data text-[0.6875rem] text-muted" title={sessionEmail}>
                {sessionEmail}
              </span>
              <button
                type="submit"
                class="text-sm text-muted transition-colors hover:text-ink"
                aria-label="Abmelden"
              >
                Logout
              </button>
            </form>
          )
        }
      </nav>
    </header>
    <main class="mx-auto w-full min-h-0 max-w-6xl flex-1 overflow-y-auto px-2 py-8">
      <slot />
    </main>
    <CommandPalette />
  </body>
</html>
