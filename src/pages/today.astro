---
import { and, asc, eq, isNotNull, isNull, lt, or, sql } from 'drizzle-orm';
import { STATUS_CLASSES, STATUS_LABELS } from '~/components/leadStatus';
import { db } from '~/db';
import { leads } from '~/db/schema';
import Layout from '~/layouts/Layout.astro';
import { formatDate, formatDateTime, startOfTomorrowVienna } from '~/lib/date';

const now = new Date();
// SQLite has no INTERVAL — compute the 7-day staleness threshold in JS.
const staleThreshold = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
// "Due" means the follow-up's calendar day is today (Vienna) or earlier. Use
// tomorrow's Vienna midnight as an exclusive upper bound so a follow-up dated
// "today" already appears from 00:00 Vienna, not just from 02:00 (raw UTC `now`).
const dueThreshold = startOfTomorrowVienna(now);

// 1) Follow-ups that are due (date reached or passed), most overdue first.
const dueFollowUps = db
  .select()
  .from(leads)
  .where(and(isNotNull(leads.followUpAt), lt(leads.followUpAt, dueThreshold)))
  .orderBy(asc(leads.followUpAt))
  .all();

// 2) Contacted leads that have gone quiet for 7+ days (or were never touched),
//    oldest contact first (NULLS FIRST).
const staleRaw = db
  .select()
  .from(leads)
  .where(
    and(
      eq(leads.status, 'contacted'),
      or(isNull(leads.lastTouchAt), lt(leads.lastTouchAt, staleThreshold)),
      // Don't nag about leads that have a future follow-up scheduled — those
      // surface again on their own date. Already-due ones land in dueFollowUps
      // (filtered out below via dueIds), so this effectively keeps only leads
      // without any follow-up.
      or(isNull(leads.followUpAt), lt(leads.followUpAt, dueThreshold)),
    ),
  )
  .orderBy(sql`${leads.lastTouchAt} is not null`, asc(leads.lastTouchAt))
  .all();

// A lead already shown as a due follow-up shouldn't appear twice.
const dueIds = new Set(dueFollowUps.map((l) => l.id));
const stale = staleRaw.filter((l) => !dueIds.has(l.id));

// Whole days between a past date and now (0 if same day or future).
const daysSince = (d: Date) =>
  Math.max(0, Math.floor((now.getTime() - d.getTime()) / (24 * 60 * 60 * 1000)));

const nothingToDo = dueFollowUps.length === 0 && stale.length === 0;

const thClass = 'px-3 py-2 font-semibold';
const tdClass = 'px-3 py-1.5 text-muted';
---

<Layout title="Heute · b-leads">
  <h1 class="text-2xl font-semibold tracking-[-0.01em]">Heute fällig</h1>

  {
    nothingToDo ? (
      <p class="mt-6 rounded-sm border border-dashed border-border p-6 text-sm text-muted">
        Nichts zu tun — alle Leads sind aktuell.
      </p>
    ) : (
      <div class="mt-6 space-y-10">
        {dueFollowUps.length > 0 && (
          <section>
            <h2 class="text-[1.125rem] font-semibold text-ink">
              Wiedervorlage fällig <span class="font-mono text-base text-muted">({dueFollowUps.length})</span>
            </h2>
            <div class="mt-3 overflow-x-auto rounded-sm border border-border bg-surface">
              <table class="w-full text-left text-sm">
                <thead class="border-b border-border bg-surface-sunken text-[0.6875rem] uppercase tracking-[0.05em] text-muted">
                  <tr>
                    <th class={thClass}>Name</th>
                    <th class={thClass}>Firma</th>
                    <th class={thClass}>Status</th>
                    <th class={thClass}>Wiedervorlage</th>
                    <th class={thClass}>Tage überfällig</th>
                  </tr>
                </thead>
                <tbody>
                  {dueFollowUps.map((lead) => (
                    <tr class="group border-b border-border last:border-0 hover:bg-surface-sunken">
                      <td class="px-3 py-1.5">
                        <a
                          href={`/leads/${lead.id}`}
                          title={lead.name}
                          class="block max-w-[18ch] truncate font-medium text-ink transition-colors group-hover:text-accent-text"
                        >
                          {lead.name}
                        </a>
                      </td>
                      <td class={tdClass}>
                        <span class="block max-w-[16ch] truncate" title={lead.company ?? undefined}>
                          {lead.company ?? '—'}
                        </span>
                      </td>
                      <td class="px-3 py-1.5">
                        <span class={`tag ${STATUS_CLASSES[lead.status]}`}>
                          {STATUS_LABELS[lead.status]}
                        </span>
                      </td>
                      <td class="px-3 py-1.5">
                        <span class="data font-medium text-danger">{formatDate(lead.followUpAt)}</span>
                      </td>
                      <td class="px-3 py-1.5">
                        <span class="data font-medium text-danger">
                          {lead.followUpAt ? daysSince(lead.followUpAt) : 0}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        {stale.length > 0 && (
          <section>
            <h2 class="text-[1.125rem] font-semibold text-ink">
              Stale Follow-ups (7+ Tage) <span class="font-mono text-base text-muted">({stale.length})</span>
            </h2>
            <div class="mt-3 overflow-x-auto rounded-sm border border-border bg-surface">
              <table class="w-full text-left text-sm">
                <thead class="border-b border-border bg-surface-sunken text-[0.6875rem] uppercase tracking-[0.05em] text-muted">
                  <tr>
                    <th class={thClass}>Name</th>
                    <th class={thClass}>Firma</th>
                    <th class={thClass}>Last Touch</th>
                    <th class={thClass}>Tage seit Last Touch</th>
                  </tr>
                </thead>
                <tbody>
                  {stale.map((lead) => (
                    <tr class="group border-b border-border last:border-0 hover:bg-surface-sunken">
                      <td class="px-3 py-1.5">
                        <a
                          href={`/leads/${lead.id}`}
                          title={lead.name}
                          class="block max-w-[18ch] truncate font-medium text-ink transition-colors group-hover:text-accent-text"
                        >
                          {lead.name}
                        </a>
                      </td>
                      <td class={tdClass}>
                        <span class="block max-w-[16ch] truncate" title={lead.company ?? undefined}>
                          {lead.company ?? '—'}
                        </span>
                      </td>
                      <td class="px-3 py-1.5">
                        <span class="data text-muted">
                          {lead.lastTouchAt ? formatDateTime(lead.lastTouchAt) : 'nie'}
                        </span>
                      </td>
                      <td class="px-3 py-1.5">
                        <span class="data text-muted">
                          {lead.lastTouchAt ? daysSince(lead.lastTouchAt) : '—'}
                        </span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}
      </div>
    )
  }
</Layout>
