---
import CsvImport from '~/components/CsvImport';
import Layout from '~/layouts/Layout.astro';

// CSV upload + client-side parsing/mapping; rows are POSTed to actions.importLeads.
// Primary use: importing outreach-wave-1.
---

<Layout title="CSV-Import · b-leads">
  <nav class="text-sm text-muted">
    <a href="/leads" class="hover:text-ink">Leads</a>
    <span class="px-1 text-border">/</span>
    <span class="text-ink">CSV-Import</span>
  </nav>
  <h1 class="mt-2 text-2xl font-semibold tracking-[-0.01em]">CSV-Import</h1>
  <p class="mt-2 max-w-xl text-sm text-muted">
    Lade eine CSV-Datei hoch, ordne die Spalten den Lead-Feldern zu und importiere die Leads. Zeilen
    mit bereits existierender E-Mail werden als Duplikate übersprungen.
  </p>

  <div class="mt-6 max-w-3xl">
    <CsvImport client:load />
  </div>
</Layout>
