---
import { actions } from 'astro:actions';
import { and, desc, like, or, type SQL, sql } from 'drizzle-orm';
import LeadsFilter from '~/components/LeadsFilter';
import { STATUS_CLASSES, STATUS_LABELS } from '~/components/leadStatus';
import { db } from '~/db';
import { LEAD_STATUSES, type LeadStatus, leads } from '~/db/schema';
import Layout from '~/layouts/Layout.astro';
import { formatDate, formatDateTime, isoDateVienna } from '~/lib/date';

// PRG: after an inline status change, redirect back to the list the user was on
// (filters preserved via the submitted returnTo) so a reload doesn't resubmit.
const statusResult = Astro.getActionResult(actions.updateLeadStatus);
if (statusResult && !statusResult.error) {
  return Astro.redirect(statusResult.data.returnTo, 303);
}

const params = Astro.url.searchParams;

// Round-trip the current filter query so the status form can return here.
const returnTo = params.toString() ? `/leads?${params.toString()}` : '/leads';

// Calendar-date comparison in the app timezone (avoids UTC-offset edge cases).
const todayIso = isoDateVienna(new Date());
function followUpClass(value: Date | null): string {
  if (!value) return 'text-gray-600';
  const iso = isoDateVienna(value);
  if (iso < todayIso) return 'text-red-600 font-medium';
  if (iso === todayIso) return 'text-amber-600 font-medium';
  return 'text-gray-600';
}

// Parse + validate the status filter against the known statuses.
const statusParam = params.get('status') ?? '';
const selectedStatuses = statusParam
  .split(',')
  .map((s) => s.trim())
  .filter((s): s is LeadStatus => (LEAD_STATUSES as readonly string[]).includes(s));

const q = (params.get('q') ?? '').trim();

const conditions: SQL[] = [];
if (selectedStatuses.length) {
  conditions.push(or(...selectedStatuses.map((s) => sql`${leads.status} = ${s}`)) as SQL);
}
if (q) {
  const term = `%${q.toLowerCase()}%`;
  conditions.push(
    or(
      like(sql`lower(${leads.name})`, term),
      like(sql`lower(${leads.email})`, term),
      like(sql`lower(${leads.company})`, term),
    ) as SQL,
  );
}

const rows = db
  .select()
  .from(leads)
  .where(conditions.length ? and(...conditions) : undefined)
  // lastTouchAt DESC NULLS LAST, then createdAt DESC. `is null` sorts nulls last.
  .orderBy(sql`${leads.lastTouchAt} is null`, desc(leads.lastTouchAt), desc(leads.createdAt))
  .all();

// Total counts per status (unfiltered) for the stats widget.
const statusCounts = db
  .select({ status: leads.status, count: sql<number>`count(*)` })
  .from(leads)
  .groupBy(leads.status)
  .all();
const countByStatus = new Map(statusCounts.map((r) => [r.status, r.count]));

// Link that toggles a status in the filter while preserving the search query.
function statusToggleHref(status: LeadStatus): string {
  const next = new Set(selectedStatuses);
  if (next.has(status)) next.delete(status);
  else next.add(status);
  const params = new URLSearchParams();
  const ordered = LEAD_STATUSES.filter((s) => next.has(s));
  if (ordered.length) params.set('status', ordered.join(','));
  if (q) params.set('q', q);
  const qs = params.toString();
  return qs ? `/leads?${qs}` : '/leads';
}
---

<Layout title="Leads · b-leads">
  <div class="flex items-center justify-between">
    <h1 class="text-xl font-semibold">Leads</h1>
    <div class="flex items-center gap-2">
      <a
        href="/leads/import"
        class="rounded border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-100"
      >
        CSV-Import
      </a>
      <a
        href="/leads/new"
        class="rounded bg-gray-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-gray-700"
      >
        Neuer Lead
      </a>
    </div>
  </div>

  <div class="mt-6 flex gap-2 overflow-x-auto pb-1">
    {
      LEAD_STATUSES.map((s) => {
        const isActive = selectedStatuses.includes(s);
        return (
          <a
            href={statusToggleHref(s)}
            aria-pressed={isActive}
            class:list={[
              'flex min-w-[7rem] shrink-0 flex-col rounded border bg-white px-3 py-2',
              isActive ? 'ring-2 ring-gray-900' : 'border-gray-200 hover:bg-gray-50',
            ]}
          >
            <span
              class={`self-start rounded-full px-2 py-0.5 text-xs font-medium ${STATUS_CLASSES[s]}`}
            >
              {STATUS_LABELS[s]}
            </span>
            <span class="mt-1 text-2xl font-semibold text-gray-900">{countByStatus.get(s) ?? 0}</span>
          </a>
        );
      })
    }
  </div>

  <div class="mt-6">
    <LeadsFilter client:load selected={selectedStatuses} query={q} />
  </div>

  {
    rows.length === 0 ? (
      <p class="mt-6 rounded border border-dashed border-gray-300 p-6 text-sm text-gray-500">
        Keine Leads gefunden.
      </p>
    ) : (
      <div class="mt-6 overflow-x-auto rounded border border-gray-200 bg-white">
        <table class="w-full text-left text-sm">
          <thead class="border-b border-gray-200 text-xs uppercase tracking-wide text-gray-500">
            <tr>
              <th class="px-4 py-2 font-medium">Name</th>
              <th class="px-4 py-2 font-medium">Firma</th>
              <th class="px-4 py-2 font-medium">E-Mail</th>
              <th class="px-4 py-2 font-medium">Status</th>
              <th class="px-4 py-2 font-medium">Last Touch</th>
              <th class="px-4 py-2 font-medium">Wiedervorlage</th>
              <th class="px-4 py-2 font-medium">Next Action</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((lead) => (
              <tr class="border-b border-gray-100 last:border-0 hover:bg-gray-50">
                <td class="px-4 py-2">
                  <a href={`/leads/${lead.id}`} class="font-medium text-gray-900 hover:underline">
                    {lead.name}
                  </a>
                </td>
                <td class="px-4 py-2 text-gray-600">{lead.company ?? '—'}</td>
                <td class="px-4 py-2 text-gray-600">{lead.email}</td>
                <td class="px-4 py-2">
                  <form method="POST" action={actions.updateLeadStatus}>
                    <input type="hidden" name="id" value={lead.id} />
                    <input type="hidden" name="returnTo" value={returnTo} />
                    <select
                      name="status"
                      onchange="this.form.requestSubmit()"
                      onwheel="event.preventDefault()"
                      aria-label="Status ändern"
                      class="rounded border border-gray-300 px-2 py-1 text-xs focus:border-gray-500 focus:outline-none"
                    >
                      {LEAD_STATUSES.map((s) => (
                        <option value={s} selected={s === lead.status}>
                          {STATUS_LABELS[s]}
                        </option>
                      ))}
                    </select>
                  </form>
                </td>
                <td class="px-4 py-2 text-gray-600">
                  {lead.lastTouchAt ? formatDateTime(lead.lastTouchAt) : '—'}
                </td>
                <td class={`px-4 py-2 ${followUpClass(lead.followUpAt)}`}>
                  {lead.followUpAt ? formatDate(lead.followUpAt) : '—'}
                </td>
                <td class="px-4 py-2 text-gray-600">{lead.nextAction ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
</Layout>
