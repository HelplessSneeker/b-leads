---
import { actions } from 'astro:actions';
import { and, desc, like, or, type SQL, sql } from 'drizzle-orm';
import LeadsFilter from '~/components/LeadsFilter';
import { STATUS_CLASSES, STATUS_LABELS } from '~/components/leadStatus';
import { db } from '~/db';
import { LEAD_STATUSES, type LeadStatus, leads } from '~/db/schema';
import Layout from '~/layouts/Layout.astro';
import { formatDate, formatDateTime, isoDateVienna } from '~/lib/date';

// PRG: after an inline status change, redirect back to the list the user was on
// (filters preserved via the submitted returnTo) so a reload doesn't resubmit.
const statusResult = Astro.getActionResult(actions.updateLeadStatus);
if (statusResult && !statusResult.error) {
  return Astro.redirect(statusResult.data.returnTo, 303);
}

const params = Astro.url.searchParams;

const isStatus = (s: string | null): s is LeadStatus =>
  !!s && (LEAD_STATUSES as readonly string[]).includes(s);

// A just-completed status change leaves a one-shot toast/flash signal in the URL
// (changed/from/to). It drives the confirmation toast + the row flash, then a
// client script strips it so a reload doesn't replay it.
const changedId = params.get('changed');
const fromStatus = params.get('from');
const toStatus = params.get('to');
const showStatusToast = !!changedId && isStatus(fromStatus) && isStatus(toStatus);

// Round-trip the current filter query so the status form can return here — but
// without the one-shot toast params, so the canonical list URL stays clean.
const cleanParams = new URLSearchParams(params);
for (const k of ['changed', 'from', 'to']) cleanParams.delete(k);
const cleanQs = cleanParams.toString();
const returnTo = cleanQs ? `/leads?${cleanQs}` : '/leads';

// Calendar-date comparison in the app timezone (avoids UTC-offset edge cases).
const todayIso = isoDateVienna(new Date());
function followUpClass(value: Date | null): string {
  if (!value) return 'text-muted';
  const iso = isoDateVienna(value);
  if (iso < todayIso) return 'text-danger font-medium';
  if (iso === todayIso) return 'text-warning font-medium';
  return 'text-muted';
}

// Parse + validate the status filter against the known statuses.
const statusParam = params.get('status') ?? '';
const selectedStatuses = statusParam
  .split(',')
  .map((s) => s.trim())
  .filter((s): s is LeadStatus => (LEAD_STATUSES as readonly string[]).includes(s));

const q = (params.get('q') ?? '').trim();

const conditions: SQL[] = [];
if (selectedStatuses.length) {
  conditions.push(or(...selectedStatuses.map((s) => sql`${leads.status} = ${s}`)) as SQL);
}
if (q) {
  const term = `%${q.toLowerCase()}%`;
  conditions.push(
    or(
      like(sql`lower(${leads.name})`, term),
      like(sql`lower(${leads.email})`, term),
      like(sql`lower(${leads.company})`, term),
    ) as SQL,
  );
}

const rows = db
  .select()
  .from(leads)
  .where(conditions.length ? and(...conditions) : undefined)
  // lastTouchAt DESC NULLS LAST, then createdAt DESC. `is null` sorts nulls last.
  .orderBy(sql`${leads.lastTouchAt} is null`, desc(leads.lastTouchAt), desc(leads.createdAt))
  .all();

// Total counts per status (unfiltered) for the stats widget.
const statusCounts = db
  .select({ status: leads.status, count: sql<number>`count(*)` })
  .from(leads)
  .groupBy(leads.status)
  .all();
const countByStatus = new Map(statusCounts.map((r) => [r.status, r.count]));

// Link that toggles a status in the filter while preserving the search query.
function statusToggleHref(status: LeadStatus): string {
  const next = new Set(selectedStatuses);
  if (next.has(status)) next.delete(status);
  else next.add(status);
  const params = new URLSearchParams();
  const ordered = LEAD_STATUSES.filter((s) => next.has(s));
  if (ordered.length) params.set('status', ordered.join(','));
  if (q) params.set('q', q);
  const qs = params.toString();
  return qs ? `/leads?${qs}` : '/leads';
}
---

<Layout title="Leads · b-leads">
  <div class="flex h-full flex-col">
  <div class="flex shrink-0 items-center justify-between">
    <h1 class="text-2xl font-semibold tracking-[-0.01em]">Leads</h1>
    <div class="flex items-center gap-2">
      <a href="/leads/import" class="btn btn-secondary">CSV-Import</a>
      <a href="/leads/new" class="btn btn-primary">Neuer Lead</a>
    </div>
  </div>

  <div class="mt-6 -mx-1 flex shrink-0 gap-2 overflow-x-auto scrollbar-none px-1 py-1">
    {
      LEAD_STATUSES.map((s) => {
        const isActive = selectedStatuses.includes(s);
        return (
          <a
            href={statusToggleHref(s)}
            aria-current={isActive ? 'true' : undefined}
            aria-label={`Filter ${STATUS_LABELS[s]}: ${countByStatus.get(s) ?? 0} Leads${isActive ? ' (aktiv)' : ''}`}
            class:list={[
              'flex min-w-[7rem] shrink-0 flex-col gap-1.5 rounded-sm border bg-surface px-3 py-2 transition-colors',
              isActive
                ? 'border-transparent ring-2 ring-accent'
                : 'border-border hover:bg-surface-sunken',
            ]}
          >
            <span class={`tag self-start ${STATUS_CLASSES[s]}`}>{STATUS_LABELS[s]}</span>
            <span class="text-xl font-medium tabular-nums text-ink">
              {countByStatus.get(s) ?? 0}
            </span>
          </a>
        );
      })
    }
  </div>

  <div class="mt-6 shrink-0">
    <LeadsFilter client:load selected={selectedStatuses} query={q} />
  </div>

  {
    rows.length === 0 ? (
      <div class="mt-6 shrink-0 rounded-sm border border-dashed border-border p-6 text-sm text-muted">
        {q || selectedStatuses.length ? (
          <p>
            Keine Leads für diesen Filter.{' '}
            <a href="/leads" class="font-medium text-accent-text hover:underline">
              Filter zurücksetzen
            </a>
          </p>
        ) : (
          <p>
            Noch keine Leads.{' '}
            <a href="/leads/new" class="font-medium text-accent-text hover:underline">
              Neuen Lead anlegen
            </a>{' '}
            oder{' '}
            <a href="/leads/import" class="font-medium text-accent-text hover:underline">
              CSV importieren
            </a>
            .
          </p>
        )}
      </div>
    ) : (
      <div class="mt-6 min-h-0 flex-1 overflow-auto scrollbar-none rounded-sm border border-border bg-surface">
        <table class="w-full text-left text-sm">
          <thead class="sticky top-0 z-10 bg-surface-sunken text-[0.6875rem] uppercase tracking-[0.05em] text-muted shadow-[inset_0_-1px_0_var(--color-border)]">
            <tr>
              {/* Priority columns (Name · Status · Wiedervorlage) stay at every
                  width; lower-priority ones reveal as the viewport grows. The full
                  record is always one tap away on the lead's detail page. */}
              <th class="px-3 py-2 font-semibold">Name</th>
              <th class="hidden px-3 py-2 font-semibold md:table-cell">Firma</th>
              <th class="hidden px-3 py-2 font-semibold lg:table-cell">E-Mail</th>
              <th class="px-3 py-2 font-semibold">Status</th>
              <th class="hidden px-3 py-2 font-semibold sm:table-cell">Letzter Kontakt</th>
              <th class="px-3 py-2 font-semibold">Wiedervorlage</th>
              <th class="hidden px-3 py-2 font-semibold lg:table-cell">Nächste Aktion</th>
            </tr>
          </thead>
          <tbody data-nav-list>
            {rows.map((lead) => (
              <tr
                class="group border-b border-border last:border-0 hover:bg-surface-sunken"
                data-nav-row
                data-href={`/leads/${lead.id}`}
                data-lead-id={lead.id}
                data-status={lead.status}
                data-name={lead.name}
                data-flash={lead.id === changedId ? '' : undefined}
              >
                <td class="px-3 py-1.5">
                  <a
                    href={`/leads/${lead.id}`}
                    title={lead.name}
                    class="block max-w-[16ch] truncate font-medium text-ink transition-colors group-hover:text-accent-text"
                  >
                    {lead.name}
                  </a>
                </td>
                <td class="hidden px-3 py-1.5 md:table-cell">
                  <span class="block max-w-[14ch] truncate text-muted" title={lead.company ?? undefined}>
                    {lead.company ?? '—'}
                  </span>
                </td>
                <td class="hidden px-3 py-1.5 lg:table-cell">
                  <span class="data block max-w-[22ch] truncate text-ink" title={lead.email}>
                    {lead.email}
                  </span>
                </td>
                <td class="px-3 py-1.5">
                  <button
                    type="button"
                    data-status-trigger
                    aria-haspopup="dialog"
                    aria-label={`Status ändern: ${lead.name} — aktuell ${STATUS_LABELS[lead.status]}`}
                    class:list={['tag tag-trigger', STATUS_CLASSES[lead.status]]}
                  >
                    {STATUS_LABELS[lead.status]}
                  </button>
                </td>
                <td class="hidden px-3 py-1.5 sm:table-cell">
                  <span class="data text-muted">
                    {lead.lastTouchAt ? formatDateTime(lead.lastTouchAt) : '—'}
                  </span>
                </td>
                <td class="px-3 py-1.5">
                  <span class={`data ${followUpClass(lead.followUpAt)}`}>
                    {lead.followUpAt ? formatDate(lead.followUpAt) : '—'}
                  </span>
                </td>
                <td class="hidden px-3 py-1.5 lg:table-cell">
                  <span class="block max-w-[24ch] truncate text-muted" title={lead.nextAction ?? undefined}>
                    {lead.nextAction ?? '—'}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
  </div>

  {
    showStatusToast && (
      <div
        id="status-toast"
        class="fixed bottom-4 right-4 z-50 max-w-sm rounded-sm border border-success-border bg-success-bg p-4 text-sm text-success shadow-[0_8px_24px_-6px_oklch(0_0_0/0.18)]"
        role="status"
        aria-live="polite"
      >
        <div class="flex items-start gap-3">
          <p class="flex-1 font-semibold">Status aktualisiert</p>
          <button
            type="button"
            data-dismiss
            class="font-medium text-success hover:opacity-70"
            aria-label="Schließen"
          >
            ✕
          </button>
        </div>
        <p class="mt-2 flex items-center gap-1.5">
          <span class:list={['tag', STATUS_CLASSES[fromStatus as LeadStatus]]}>
            {STATUS_LABELS[fromStatus as LeadStatus]}
          </span>
          <span aria-hidden="true" class="data text-muted">→</span>
          <span class:list={['tag', STATUS_CLASSES[toStatus as LeadStatus]]}>
            {STATUS_LABELS[toStatus as LeadStatus]}
          </span>
        </p>
        <form method="POST" action={actions.updateLeadStatus} class="mt-3">
          <input type="hidden" name="id" value={changedId} />
          <input type="hidden" name="status" value={fromStatus} />
          <input type="hidden" name="returnTo" value={returnTo} />
          <button type="submit" class="font-medium text-success underline hover:opacity-70">
            Rückgängig
          </button>
        </form>
      </div>
    )
  }
</Layout>

<script>
  // One-shot status toast. Runs on every astro:page-load (not just the first):
  // hoisted module scripts execute once per session, so the ClientRouter event is
  // what re-wires the freshly-rendered toast after each status-change navigation.
  // The toast persists until dismissed (the status change is now confirmable, so
  // the undo is for intentional regret — no countdown racing the operator). It's
  // replaced by the next change's render, so it never piles up.
  function initStatusToast() {
    const toast = document.getElementById('status-toast');
    if (!toast) return;
    // Strip the changed/from/to params so a manual reload won't replay the toast.
    const url = new URL(window.location.href);
    let dirty = false;
    for (const k of ['changed', 'from', 'to']) {
      if (url.searchParams.has(k)) {
        url.searchParams.delete(k);
        dirty = true;
      }
    }
    if (dirty) history.replaceState(null, '', url.pathname + url.search);
    const hide = () => toast.setAttribute('hidden', '');
    toast.querySelector('[data-dismiss]')?.addEventListener('click', hide);
  }
  document.addEventListener('astro:page-load', initStatusToast);
</script>
