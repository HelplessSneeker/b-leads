---
import { actions, isInputError } from 'astro:actions';
import { desc, eq } from 'drizzle-orm';
import ActivityForm from '~/components/ActivityForm.astro';
import ActivityTimeline from '~/components/ActivityTimeline.astro';
import { STATUS_CLASSES, STATUS_LABELS } from '~/components/leadStatus';
import { db } from '~/db';
import { activities, leads } from '~/db/schema';
import Layout from '~/layouts/Layout.astro';
import { formatDate, formatDateTime, isoDateVienna } from '~/lib/date';
import { renderMarkdown } from '~/lib/markdown';

const { id } = Astro.params;
if (!id) return Astro.rewrite('/404');

const deleteResult = Astro.getActionResult(actions.deleteLead);
const createActivityResult = Astro.getActionResult(actions.createActivity);
const updateActivityResult = Astro.getActionResult(actions.updateActivity);
const deleteActivityResult = Astro.getActionResult(actions.deleteActivity);
const analyzeActivityResult = Astro.getActionResult(actions.analyzeActivity);

// PRG: redirect after a successful mutation so a reload doesn't resubmit.
if (deleteResult && !deleteResult.error) return Astro.redirect('/leads', 303);
if (createActivityResult && !createActivityResult.error) return Astro.redirect(`/leads/${id}`, 303);
if (updateActivityResult && !updateActivityResult.error) return Astro.redirect(`/leads/${id}`, 303);
if (deleteActivityResult && !deleteActivityResult.error) return Astro.redirect(`/leads/${id}`, 303);
if (analyzeActivityResult && !analyzeActivityResult.error)
  return Astro.redirect(`/leads/${id}`, 303);

const lead = db.select().from(leads).where(eq(leads.id, id)).get();
if (!lead) return Astro.rewrite('/404');

const leadActivities = db
  .select()
  .from(activities)
  .where(eq(activities.leadId, id))
  .orderBy(desc(activities.occurredAt))
  .all();

// On a failed activity mutation, keep what the user typed (middleware parsed a
// clone, so the original body is still readable here).
let submitted: FormData | null = null;
if (Astro.request.method === 'POST') {
  try {
    submitted = await Astro.request.formData();
  } catch {
    submitted = null;
  }
}

const activityErrors =
  createActivityResult && isInputError(createActivityResult.error)
    ? createActivityResult.error.fields
    : undefined;
const editActivityErrors =
  updateActivityResult && isInputError(updateActivityResult.error)
    ? updateActivityResult.error.fields
    : undefined;

// A failed create/edit doesn't redirect; reopen the dialog in the matching mode with
// the submitted values + error. Mode is decided by which action errored.
const dialogOpen = Boolean(activityErrors || editActivityErrors);
const dialogMode: 'create' | 'edit' = editActivityErrors ? 'edit' : 'create';
const dialogEditId = dialogMode === 'edit' ? (submitted?.get('id')?.toString() ?? null) : null;
const dialogErrors = editActivityErrors ?? activityErrors;

// Calendar-date comparison in the app timezone (matches the leads list).
const todayIso = isoDateVienna(new Date());
function followUpClass(value: Date | null): string {
  if (!value) return 'text-ink';
  const iso = isoDateVienna(value);
  if (iso < todayIso) return 'text-danger font-medium';
  if (iso === todayIso) return 'text-warning font-medium';
  return 'text-ink';
}
---

<Layout title={`${lead.name} · b-leads`}>
  <nav class="text-sm text-muted">
    <a href="/leads" class="hover:text-ink">Leads</a>
    <span class="px-1 text-muted">/</span>
    <span class="text-ink">{lead.name}</span>
  </nav>

  <div class="mt-2 flex items-start justify-between gap-4">
    <div class="min-w-0">
      <h1 class="break-words text-2xl font-semibold tracking-[-0.01em]">{lead.name}</h1>
      <span class={`mt-2 inline-flex tag ${STATUS_CLASSES[lead.status]}`}>
        {STATUS_LABELS[lead.status]}
      </span>
    </div>
    <div class="flex shrink-0 items-center gap-2">
      <a href={`/leads/${lead.id}/edit`} class="btn btn-primary">Bearbeiten</a>
      <form method="POST" action={actions.deleteLead} onsubmit="return confirm('Lead wirklich löschen?')">
        <input type="hidden" name="id" value={lead.id} />
        <button type="submit" class="btn btn-danger">Löschen</button>
      </form>
    </div>
  </div>

  <div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-3">
    {/* Activities: the working column — left and wide on lg, last on mobile. */}
    <section class="order-2 lg:order-1 lg:col-span-2">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-[1.125rem] font-semibold text-ink">
          Aktivitäten <span class="tabular-nums text-base text-muted">({leadActivities.length})</span>
        </h2>
        <button type="button" data-activity-add class="btn btn-secondary">Aktivität hinzufügen</button>
      </div>
      <ActivityTimeline activities={leadActivities} />
    </section>

    {/* Reference column: facts + notes, sticky beside the scrolling timeline on lg,
        first on mobile. */}
    <aside class="order-1 space-y-8 self-start lg:order-2 lg:sticky lg:top-6">
      <section class="rounded-sm border border-border bg-surface p-4">
        <dl class="grid grid-cols-2 gap-x-6 gap-y-3 break-words text-sm">
          <div class="min-w-0">
            <dt class="text-[0.6875rem] font-semibold uppercase tracking-[0.05em] text-muted">Firma</dt>
            <dd class="mt-0.5 text-ink">{lead.company ?? '—'}</dd>
          </div>
          <div class="min-w-0">
            <dt class="text-[0.6875rem] font-semibold uppercase tracking-[0.05em] text-muted">Rolle</dt>
            <dd class="mt-0.5 text-ink">{lead.role ?? '—'}</dd>
          </div>
          <div class="min-w-0">
            <dt class="text-[0.6875rem] font-semibold uppercase tracking-[0.05em] text-muted">E-Mail</dt>
            <dd class="mt-0.5">
              <a href={`mailto:${lead.email}`} class="data text-accent-text [overflow-wrap:anywhere] hover:underline">{lead.email}</a>
            </dd>
          </div>
          <div class="min-w-0">
            <dt class="text-[0.6875rem] font-semibold uppercase tracking-[0.05em] text-muted">Quelle</dt>
            <dd class="mt-0.5 text-ink">{lead.source}</dd>
          </div>
          <div class="min-w-0">
            <dt class="text-[0.6875rem] font-semibold uppercase tracking-[0.05em] text-muted">Nächste Aktion</dt>
            <dd class="mt-0.5 text-ink">{lead.nextAction ?? '—'}</dd>
          </div>
          <div class="min-w-0">
            <dt class="text-[0.6875rem] font-semibold uppercase tracking-[0.05em] text-muted">Wiedervorlage</dt>
            <dd class={`mt-0.5 data ${followUpClass(lead.followUpAt)}`}>
              {lead.followUpAt ? formatDate(lead.followUpAt) : '—'}
            </dd>
          </div>
          <div class="min-w-0">
            <dt class="text-[0.6875rem] font-semibold uppercase tracking-[0.05em] text-muted">Letzter Kontakt</dt>
            <dd class="mt-0.5 data text-ink">{lead.lastTouchAt ? formatDateTime(lead.lastTouchAt) : '—'}</dd>
          </div>
          <div class="min-w-0">
            <dt class="text-[0.6875rem] font-semibold uppercase tracking-[0.05em] text-muted">Erstellt</dt>
            <dd class="mt-0.5 data text-ink">{formatDateTime(lead.createdAt)}</dd>
          </div>
          <div class="min-w-0">
            <dt class="text-[0.6875rem] font-semibold uppercase tracking-[0.05em] text-muted">Aktualisiert</dt>
            <dd class="mt-0.5 data text-ink">{formatDateTime(lead.updatedAt)}</dd>
          </div>
        </dl>
      </section>

      <section>
        <h2 class="text-[1.125rem] font-semibold text-ink">Notizen</h2>
        {
          lead.notes ? (
            <div class="notes-rendered mt-2" set:html={renderMarkdown(lead.notes)} />
          ) : (
            <p class="mt-2 text-sm italic text-muted">Keine Notizen.</p>
          )
        }
      </section>
    </aside>
  </div>

  <ActivityForm
    leadId={lead.id}
    submitted={submitted}
    fieldErrors={dialogErrors}
    open={dialogOpen}
    mode={dialogMode}
    editId={dialogEditId}
  />
</Layout>
