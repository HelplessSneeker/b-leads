---
import { actions, isInputError } from 'astro:actions';
import { desc, eq } from 'drizzle-orm';
import ActivityForm from '~/components/ActivityForm.astro';
import ActivityTimeline from '~/components/ActivityTimeline.astro';
import { STATUS_CLASSES, STATUS_LABELS } from '~/components/leadStatus';
import { db } from '~/db';
import { activities, leads } from '~/db/schema';
import Layout from '~/layouts/Layout.astro';
import { formatDate, formatDateTime, isoDateVienna } from '~/lib/date';
import { renderMarkdown } from '~/lib/markdown';

const { id } = Astro.params;
if (!id) return new Response('Not found', { status: 404 });

const deleteResult = Astro.getActionResult(actions.deleteLead);
const createActivityResult = Astro.getActionResult(actions.createActivity);
const updateActivityResult = Astro.getActionResult(actions.updateActivity);
const deleteActivityResult = Astro.getActionResult(actions.deleteActivity);

// PRG: redirect after a successful mutation so a reload doesn't resubmit.
if (deleteResult && !deleteResult.error) return Astro.redirect('/leads', 303);
if (createActivityResult && !createActivityResult.error) return Astro.redirect(`/leads/${id}`, 303);
if (updateActivityResult && !updateActivityResult.error) return Astro.redirect(`/leads/${id}`, 303);
if (deleteActivityResult && !deleteActivityResult.error) return Astro.redirect(`/leads/${id}`, 303);

const lead = db.select().from(leads).where(eq(leads.id, id)).get();
if (!lead) return new Response('Not found', { status: 404 });

const leadActivities = db
  .select()
  .from(activities)
  .where(eq(activities.leadId, id))
  .orderBy(desc(activities.occurredAt))
  .all();

// On a failed activity mutation, keep what the user typed (middleware parsed a
// clone, so the original body is still readable here).
let submitted: FormData | null = null;
if (Astro.request.method === 'POST') {
  try {
    submitted = await Astro.request.formData();
  } catch {
    submitted = null;
  }
}

const activityErrors =
  createActivityResult && isInputError(createActivityResult.error)
    ? createActivityResult.error.fields
    : undefined;
const editActivityErrors =
  updateActivityResult && isInputError(updateActivityResult.error)
    ? updateActivityResult.error.fields
    : undefined;
const editingId = Astro.url.searchParams.get('edit');

// Calendar-date comparison in the app timezone (matches the leads list).
const todayIso = isoDateVienna(new Date());
function followUpClass(value: Date | null): string {
  if (!value) return 'text-gray-900';
  const iso = isoDateVienna(value);
  if (iso < todayIso) return 'text-red-600 font-medium';
  if (iso === todayIso) return 'text-amber-600 font-medium';
  return 'text-gray-900';
}
---

<Layout title={`${lead.name} · b-leads`}>
  <nav class="text-sm text-gray-500">
    <a href="/leads" class="hover:text-gray-900">Leads</a>
    <span class="px-1">/</span>
    <span class="text-gray-900">{lead.name}</span>
  </nav>

  <div class="mt-2 flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold">{lead.name}</h1>
      <span
        class={`mt-2 inline-block rounded-full px-3 py-1 text-sm font-medium ${STATUS_CLASSES[lead.status]}`}
      >
        {STATUS_LABELS[lead.status]}
      </span>
    </div>
    <div class="flex shrink-0 items-center gap-2">
      <a
        href={`/leads/${lead.id}/edit`}
        class="rounded bg-gray-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-gray-700"
      >
        Bearbeiten
      </a>
      <form method="POST" action={actions.deleteLead} onsubmit="return confirm('Lead wirklich löschen?')">
        <input type="hidden" name="id" value={lead.id} />
        <button
          type="submit"
          class="rounded border border-red-300 px-3 py-1.5 text-sm font-medium text-red-600 hover:bg-red-50"
        >
          Löschen
        </button>
      </form>
    </div>
  </div>

  <section class="mt-8 max-w-xl rounded border border-gray-200 bg-white p-4">
    <dl class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">Firma</dt>
        <dd class="text-gray-900">{lead.company ?? '—'}</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">Rolle</dt>
        <dd class="text-gray-900">{lead.role ?? '—'}</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">E-Mail</dt>
        <dd>
          <a href={`mailto:${lead.email}`} class="text-blue-600 hover:underline">{lead.email}</a>
        </dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">Quelle</dt>
        <dd class="text-gray-900">{lead.source}</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">Next Action</dt>
        <dd class="text-gray-900">{lead.nextAction ?? '—'}</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">Wiedervorlage</dt>
        <dd class={followUpClass(lead.followUpAt)}>
          {lead.followUpAt ? formatDate(lead.followUpAt) : '—'}
        </dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">Last Touch</dt>
        <dd class="text-gray-900">{lead.lastTouchAt ? formatDateTime(lead.lastTouchAt) : '—'}</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">Erstellt</dt>
        <dd class="text-gray-900">{formatDateTime(lead.createdAt)}</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-gray-500">Aktualisiert</dt>
        <dd class="text-gray-900">{formatDateTime(lead.updatedAt)}</dd>
      </div>
    </dl>
  </section>

  <section class="mt-8 max-w-xl">
    <h2 class="font-medium text-gray-900">Notizen</h2>
    {
      lead.notes ? (
        <div class="notes-rendered mt-2" set:html={renderMarkdown(lead.notes)} />
      ) : (
        <p class="mt-2 text-sm italic text-gray-500">Keine Notizen.</p>
      )
    }
  </section>

  <section class="mt-8 max-w-xl">
    <h2 class="font-medium text-gray-900">Aktivitäten ({leadActivities.length})</h2>
    <ActivityForm leadId={lead.id} fieldErrors={activityErrors} submitted={submitted} />
    <ActivityTimeline
      activities={leadActivities}
      editingId={editingId}
      fieldErrors={editActivityErrors}
      submitted={submitted}
    />
  </section>
</Layout>
