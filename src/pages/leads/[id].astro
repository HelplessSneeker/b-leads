---
import Layout from '~/layouts/Layout.astro';

const { id } = Astro.params;

// Phase 1 TODO: load lead by id (404 if missing), inline-editable fields
// (updateLead), Markdown notes editor + preview, replies timeline (empty in
// Phase 1), delete with confirm (deleteLead). Inline edit — no separate /edit route.
---

<Layout title="Lead · b-leads">
  <a href="/leads" class="text-sm text-gray-500 hover:text-gray-900">&larr; Zurück zu Leads</a>
  <h1 class="mt-2 text-xl font-semibold">Lead-Detail</h1>
  <p class="mt-1 text-sm text-gray-400">id: {id}</p>
  <p class="mt-6 rounded border border-dashed border-gray-300 p-6 text-sm text-gray-500">
    Platzhalter — editierbare Felder, Notes (Markdown) und Replies-Timeline folgen
    in Phase 1.
  </p>
</Layout>
