---
import { actions, isInputError } from 'astro:actions';
import { desc, eq } from 'drizzle-orm';
import { STATUS_LABELS } from '~/components/leadStatus';
import NotesEditor from '~/components/NotesEditor';
import { db } from '~/db';
import { LEAD_STATUSES, leads, replies } from '~/db/schema';
import Layout from '~/layouts/Layout.astro';
import { formatDateTime } from '~/lib/date';
import { getSources } from '~/lib/sources';

const { id } = Astro.params;
if (!id) return new Response('Not found', { status: 404 });

const updateResult = Astro.getActionResult(actions.updateLead);
const deleteResult = Astro.getActionResult(actions.deleteLead);

// PRG: redirect after a successful mutation so a reload doesn't resubmit.
if (deleteResult && !deleteResult.error) return Astro.redirect('/leads', 303);
if (updateResult && !updateResult.error) return Astro.redirect(`/leads/${id}`, 303);

const lead = db.select().from(leads).where(eq(leads.id, id)).get();
if (!lead) return new Response('Not found', { status: 404 });

const leadReplies = db
  .select()
  .from(replies)
  .where(eq(replies.leadId, id))
  .orderBy(desc(replies.createdAt))
  .all();

// On a failed update, keep what the user typed (middleware parsed a clone, so the
// original body is still readable here).
let submitted: FormData | null = null;
if (Astro.request.method === 'POST') {
  try {
    submitted = await Astro.request.formData();
  } catch {
    submitted = null;
  }
}

const fieldErrors =
  updateResult && isInputError(updateResult.error) ? updateResult.error.fields : undefined;
const isConflict =
  !!updateResult?.error &&
  !isInputError(updateResult.error) &&
  updateResult.error.code === 'CONFLICT';

const value = (key: string, fallback: string) => {
  const v = submitted?.get(key);
  return typeof v === 'string' ? v : fallback;
};

const selectedStatus = value('status', lead.status);
const notesValue = value('notes', lead.notes ?? '');
const sources = getSources();

const fieldClass =
  'mt-1 w-full rounded border border-gray-300 px-3 py-1.5 text-sm focus:border-gray-500 focus:outline-none';
const labelClass = 'block text-sm font-medium text-gray-700';
const errorClass = 'mt-1 text-sm text-red-600';
---

<Layout title={`${lead.name} · b-leads`}>
  <nav class="text-sm text-gray-500">
    <a href="/leads" class="hover:text-gray-900">Leads</a>
    <span class="px-1">/</span>
    <span class="text-gray-900">{lead.name}</span>
  </nav>

  <h1 class="mt-2 text-xl font-semibold">{lead.name}</h1>

  {
    isConflict && (
      <div class="mt-4 rounded border border-red-200 bg-red-50 p-4 text-sm text-red-700">
        {updateResult?.error.message}
      </div>
    )
  }

  <form method="POST" action={actions.updateLead} class="mt-6 max-w-xl space-y-4">
    <input type="hidden" name="id" value={lead.id} />

    <div>
      <label class={labelClass} for="name">Name</label>
      <input id="name" name="name" type="text" value={value('name', lead.name)} class={fieldClass} />
      {fieldErrors?.name && <p class={errorClass}>{fieldErrors.name[0]}</p>}
    </div>

    <div>
      <label class={labelClass} for="email">E-Mail</label>
      <input id="email" name="email" type="email" value={value('email', lead.email)} class={fieldClass} />
      {fieldErrors?.email && <p class={errorClass}>{fieldErrors.email[0]}</p>}
    </div>

    <div>
      <label class={labelClass} for="company">Firma</label>
      <input id="company" name="company" type="text" value={value('company', lead.company ?? '')} class={fieldClass} />
    </div>

    <div>
      <label class={labelClass} for="role">Rolle</label>
      <input id="role" name="role" type="text" value={value('role', lead.role ?? '')} class={fieldClass} />
    </div>

    <div>
      <label class={labelClass} for="source">Quelle</label>
      <input id="source" name="source" type="text" value={value('source', lead.source)} class={fieldClass} list="sources" />
      <datalist id="sources">{sources.map((s) => <option value={s} />)}</datalist>
      {fieldErrors?.source && <p class={errorClass}>{fieldErrors.source[0]}</p>}
    </div>

    <div>
      <label class={labelClass} for="status">Status</label>
      <select id="status" name="status" class={fieldClass}>
        {
          LEAD_STATUSES.map((s) => (
            <option value={s} selected={s === selectedStatus}>
              {STATUS_LABELS[s]}
            </option>
          ))
        }
      </select>
    </div>

    <div>
      <label class={labelClass} for="nextAction">Next Action</label>
      <input id="nextAction" name="nextAction" type="text" value={value('nextAction', lead.nextAction ?? '')} class={fieldClass} />
    </div>

    <div>
      <span class={labelClass}>Notizen (Markdown)</span>
      <div class="mt-1">
        <NotesEditor client:load value={notesValue} />
      </div>
    </div>

    <div>
      <button
        type="submit"
        class="rounded bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700"
      >
        Speichern
      </button>
    </div>
  </form>

  <section class="mt-8 max-w-xl rounded border border-gray-200 bg-white p-4 text-sm text-gray-600">
    <h2 class="font-medium text-gray-900">Metadaten</h2>
    <dl class="mt-2 grid grid-cols-[auto_1fr] gap-x-4 gap-y-1">
      <dt class="text-gray-500">Erstellt</dt>
      <dd>{formatDateTime(lead.createdAt)}</dd>
      <dt class="text-gray-500">Aktualisiert</dt>
      <dd>{formatDateTime(lead.updatedAt)}</dd>
      <dt class="text-gray-500">Last Touch</dt>
      <dd>{lead.lastTouchAt ? formatDateTime(lead.lastTouchAt) : '—'}</dd>
    </dl>
  </section>

  <section class="mt-8 max-w-xl">
    <h2 class="font-medium text-gray-900">Antworten ({leadReplies.length})</h2>
    <p class="mt-2 rounded border border-dashed border-gray-300 p-6 text-sm text-gray-500">
      Noch keine Antworten — IMAP-Sync kommt in Phase 2.
    </p>
  </section>

  <section class="mt-8 max-w-xl border-t border-gray-200 pt-6">
    <form method="POST" action={actions.deleteLead} onsubmit="return confirm('Lead wirklich löschen?')">
      <input type="hidden" name="id" value={lead.id} />
      <button
        type="submit"
        class="rounded border border-red-300 px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-50"
      >
        Löschen
      </button>
    </form>
  </section>
</Layout>
